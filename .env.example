# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# Database (local dev)
POSTGRES_USER=shopright
POSTGRES_PASSWORD=your_dev_password
POSTGRES_DB=shopright

# Services (local dev)
DATABASE_URL=postgresql://shopright:your_dev_password@postgres:5432/shopright
DATABASE_URL_ASYNC=postgresql+asyncpg://shopright:your_dev_password@postgres:5432/shopright
JWT_SECRET=your_dev_jwt_secret

# GCP (optional for local dev — only needed for BigQuery/chatbot analytics)
GCP_PROJECT_ID=

# Gemini (required for chatbot)
GEMINI_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CHATBOT_URL=http://localhost:8004
